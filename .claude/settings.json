{
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "tdd@glebis-skills": true,
    "expo@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/Dev/matchday/.claude/hooks/post-tool-use.sh",
            "timeout": 60,
            "asyncRewake": true,
            "rewakeMessage": "Tests failed after your edit:"
          }
        ]
      }
    ]
  }
}
